# Supabase — copiá estos valores desde tu proyecto en supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Solo necesario si usas features admin (opcional en MVP)
# SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# OpenAI — necesario para sugerencia de categorías por embeddings (Phase 2)
# Obtené tu key en: https://platform.openai.com/api-keys
# Si no se configura, el sistema igual funciona con historial + fuzzy (Phase 1)
# OPENAI_API_KEY=sk-...

# Alpha Vantage — fuente de respaldo para velas diarias del análisis técnico
# (se usa solo si Finnhub/Yahoo/Stooq fallan desde tu red). Key gratis en 1 minuto:
# https://www.alphavantage.co/support/#api-key — 25 requests/día alcanza de sobra
# con el cache de 12 h de la app.
# ALPHAVANTAGE_API_KEY=TU_KEY
